#!/usr/bin/env node

const { spawn } = require("child_process");
const path = require("path");

// Helper function to run commands safely
function runCommand(command, args = [], options = {}) {
  return new Promise((resolve, reject) => {
    const child = spawn(command, args, {
      stdio: "inherit",
      ...options,
    });

    child.on("close", (code) => {
      if (code === 0) {
        resolve();
      } else {
        reject(new Error(`Command failed with exit code ${code}`));
      }
    });

    child.on("error", (error) => {
      reject(error);
    });
  });
}

// Get the absolute path to the scripts directory
const scriptsDir = path.join(__dirname, "scripts");
const apiDir = path.join(__dirname, "api");

function takeFlagValue(args, flagLong, flagShort) {
  const idxLong = flagLong ? args.indexOf(flagLong) : -1;
  const idxShort = flagShort ? args.indexOf(flagShort) : -1;
  const idx = idxLong !== -1 ? idxLong : idxShort !== -1 ? idxShort : -1;
  if (idx === -1) return { value: undefined, rest: args };

  const next = args[idx + 1];
  if (next == null || next.startsWith("-")) {
    return { value: undefined, rest: args.filter((_, i) => i !== idx) };
  }
  const rest = args.filter((_, i) => i !== idx && i !== idx + 1);
  return { value: next, rest };
}

function takeEqualsFlagValue(args, flagLong) {
  if (!flagLong) return { value: undefined, rest: args };
  const prefix = `${flagLong}=`;
  const match = args.find((a) => a.startsWith(prefix));
  if (!match) return { value: undefined, rest: args };
  const value = match.slice(prefix.length);
  const rest = args.filter((a) => a !== match);
  return { value, rest };
}

// Run command
async function run(container) {
  try {
    console.log(`🚀 Running Docker container: ${container ?? ""}`);
    await runCommand("node", [
      path.join(scriptsDir, "run.js"),
      container ?? "",
    ]);
    console.log(`✅ Container ${container} running successfully!`);
  } catch (error) {
    console.error(`❌ Container ${container} failed to run:`, error.message);
    process.exit(1);
  }
}

// Logs command
async function logs(container) {
  try {
    console.log(`🚀 Logging container: ${container}`);
    await runCommand("node", [path.join(scriptsDir, "logs.js"), container]);
    console.log(`✅ Logs ${container} completed successfully!`);
  } catch (error) {
    console.error(`❌ Logs ${container} failed:`, error.message);
    process.exit(1);
  }
}

// List command
async function list() {
  try {
    console.log(`🚀 Listing running containers...`);
    await runCommand("node", [path.join(scriptsDir, "list.js")]);
  } catch (error) {
    console.error(`❌ List failed:`, error.message);
    process.exit(1);
  }
}

// Inject command
async function inject(container) {
  try {
    console.log(`🚀 Injecting into container: ${container}`);
    await runCommand("node", [path.join(scriptsDir, "inject.js"), container]);
  } catch (error) {
    console.error(`❌ Inject failed:`, error.message);
    process.exit(1);
  }
}

// Build command
async function build(target) {
  if (!target || !["app", "api"].includes(target)) {
    console.error("❌ Error: Target must be 'app' or 'api'");
    console.log("Usage: epic build [app|api]");
    process.exit(1);
  }

  try {
    console.log(`🚀 Building ${target}...`);
    await runCommand("node", [path.join(scriptsDir, "build.js"), target]);
    console.log(`✅ ${target} build completed successfully!`);
  } catch (error) {
    console.error(`❌ ${target} build failed:`, error.message);
    process.exit(1);
  }
}

// Deploy command
async function deploy(action) {
  if (!action || !["apply", "delete"].includes(action)) {
    console.error("❌ Error: Action must be 'apply' or 'delete'");
    console.log("Usage: epic deploy [apply|delete]");
    process.exit(1);
  }

  try {
    console.log(`🚀 Deploying ${action}...`);
    await runCommand("node", [path.join(scriptsDir, "deploy.js"), action]);
    console.log(`✅ Deploy ${action} completed successfully!`);
  } catch (error) {
    console.error(`❌ Deploy ${action} failed:`, error.message);
    process.exit(1);
  }
}

// Remove command
async function remove(target) {
  try {
    console.log(`🚀 Removing containers...`);
    const args = [path.join(scriptsDir, "remove.js")];
    if (target) {
      args.push(target);
    }
    await runCommand("node", args);
  } catch (error) {
    console.error(`❌ Remove failed:`, error.message);
    process.exit(1);
  }
}

// Restart command
async function restart(target, args = []) {
  try {
    console.log(`🔁 Restarting ${target ?? "containers"}...`);
    const nodeArgs = [path.join(scriptsDir, "restart.js")];
    if (target) nodeArgs.push(target);
    if (args.length > 0) nodeArgs.push(...args);
    await runCommand("node", nodeArgs);
  } catch (error) {
    console.error(`❌ Restart failed:`, error.message);
    process.exit(1);
  }
}

async function migrations(action, args = []) {
  try {
    if (!action || !["generate", "run", "revert"].includes(action)) {
      console.error("❌ Error: Action must be 'generate', 'run', or 'revert'");
      console.log(
        'Usage: epic migrations generate --name="..." | epic migrations run | epic migrations revert',
      );
      process.exit(1);
    }

    if (action === "generate") {
      // Support:
      // - epic migrations generate --name Foo
      // - epic migrations generate --name=Foo
      // - epic migrations generate Foo
      const eq = takeEqualsFlagValue(args, "--name");
      const spaced = takeFlagValue(eq.rest, "--name", "-n");
      let name = eq.value ?? spaced.value;
      let rest = spaced.rest;
      if (!name && rest[0] && !rest[0].startsWith("-")) {
        name = rest[0];
        rest = rest.slice(1);
      }
      if (!name) {
        console.error('❌ Error: Missing migration name (use --name="...")');
        console.log('Usage: epic migrations generate --name="AddFooBar"');
        process.exit(1);
      }

      console.log(`🚀 Generating migration: ${name}`);
      const npmArgs = ["run", "migrations:generate"];
      if (rest.length > 0) npmArgs.push("--", ...rest);

      await runCommand("npm", npmArgs, {
        cwd: apiDir,
        env: { ...process.env, npm_config_name: name },
      });
      console.log("✅ Migration generated successfully!");
      return;
    }

    if (action === "run") {
      console.log("🚀 Running migrations...");
      const npmArgs = ["run", "migrations:run"];
      if (args.length > 0) npmArgs.push("--", ...args);
      await runCommand("npm", npmArgs, { cwd: apiDir });
      console.log("✅ Migrations ran successfully!");
      return;
    }

    if (action === "revert") {
      console.log("🚀 Reverting last migration...");
      const npmArgs = ["run", "migrations:revert"];
      if (args.length > 0) npmArgs.push("--", ...args);
      await runCommand("npm", npmArgs, { cwd: apiDir });
      console.log("✅ Migration reverted successfully!");
      return;
    }
  } catch (error) {
    console.error(`❌ Migrations ${action} failed:`, error.message);
    process.exit(1);
  }
}

async function postgres(action, args = []) {
  try {
    if (!action || ["help", "--help", "-h"].includes(action)) {
      await runCommand("node", [path.join(scriptsDir, "postgres.js"), "help"]);
      return;
    }

    if (!["rotate", "list", "restore", "restore-latest"].includes(action)) {
      console.error(
        "❌ Error: Postgres action must be 'rotate', 'list', 'restore', or 'restore-latest'",
      );
      console.log(
        "Usage: epic postgres rotate | list | restore <datetime|name|prefix> | restore-latest",
      );
      process.exit(1);
    }

    // Postgres data dir is often owned by root/docker; default to sudo unless explicitly disabled.
    const noSudo = args.includes("--no-sudo");
    const forceSudo = args.includes("--sudo");
    const cleanedArgs = args.filter((a) => a !== "--no-sudo" && a !== "--sudo");

    const canUid = typeof process.getuid === "function";
    const isRoot = canUid ? process.getuid() === 0 : false;
    const shouldSudo = !isRoot && (forceSudo || !noSudo);

    if (shouldSudo) {
      const hasTty =
        Boolean(process.stdin && process.stdin.isTTY) ||
        Boolean(process.stderr && process.stderr.isTTY) ||
        Boolean(process.stdout && process.stdout.isTTY);
      if (!hasTty) {
        console.warn(
          "⚠️  Postgres command would use sudo, but no TTY is available for password prompt.\n" +
            "   Run this in an interactive terminal, or pass --no-sudo (may fail if permissions are required).",
        );
        await runCommand("node", [
          path.join(scriptsDir, "postgres.js"),
          action,
          ...cleanedArgs,
        ]);
        return;
      }

      // Use the absolute node executable path; sudo often has a restricted PATH
      // which can cause "sudo: node: command not found".
      const nodeExec = process.execPath;
      await runCommand("sudo", [
        nodeExec,
        path.join(scriptsDir, "postgres.js"),
        action,
        ...cleanedArgs,
      ]);
      return;
    }

    await runCommand("node", [
      path.join(scriptsDir, "postgres.js"),
      action,
      ...cleanedArgs,
    ]);
  } catch (error) {
    console.error(`❌ Postgres ${action} failed:`, error.message);
    process.exit(1);
  }
}

// Main CLI logic
function main() {
  const args = process.argv.slice(2);
  const [command, ...rest] = args;
  const target = rest[0];

  switch (command) {
    case "build":
      build(target);
      break;
    case "deploy":
      deploy(target);
      break;
    case "run":
      run(target);
      break;
    case "logs":
      logs(target);
      break;
    case "list":
      list();
      break;
    case "inject":
      inject(target);
      break;
    case "remove":
      remove(target);
      break;
    case "restart":
      // restart has an optional <service> arg; if the first token is a flag, treat it as no service.
      if (rest[0] && rest[0].startsWith("-")) {
        restart(undefined, rest);
      } else {
        restart(rest[0], rest.slice(1));
      }
      break;
    case "migrations":
      migrations(rest[0], rest.slice(1));
      break;
    case "postgres":
      postgres(rest[0], rest.slice(1));
      break;
    case "help":
    case "--help":
    case "-h":
      showHelp();
      break;
    default:
      console.error("❌ Error: Unknown command");
      showHelp();
      process.exit(1);
  }
}

