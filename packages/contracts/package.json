{
  "name": "@epicstory/contracts",
  "version": "0.0.1",
  "private": true,
  "description": "Shared HTTP contract types for API and clients",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:prod": "tsup",
    "build": "SKIP_TSUP_DTS=1 tsup && tsc --emitDeclarationOnly"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.16.0"
  },
  "devDependencies": {
    "@tiptap/core": "^3.22.3",
    "tsup": "^8.5.1",
    "typescript": "~5.4.0"
  }
}
