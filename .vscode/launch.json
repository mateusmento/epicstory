{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Debug App (Chrome)",
      "url": "https://epicstory.io/",
      "webRoot": "${workspaceFolder}/app",
      "sourceMaps": true,
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/app/node_modules/**"
      ]
    },
    {
      "type": "msedge",
      "request": "launch",
      "name": "Debug App (Edge)",
      "url": "https://epicstory.io/",
      "webRoot": "${workspaceFolder}/app",
      "sourceMaps": true,
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/app/node_modules/**"
      ]
    },
    {
      "type": "chrome",
      "request": "attach",
      "name": "Attach to Chrome (start Chrome with --remote-debugging-port=9222)",
      "port": 9222,
      "url": "https://epicstory.io/",
      "webRoot": "${workspaceFolder}/app",
      "sourceMaps": true,
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/app/node_modules/**"
      ]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to API (Docker)",
      "port": 9229,
      "address": "localhost",
      "localRoot": "${workspaceFolder}/api",
      "remoteRoot": "/home/node/app",
      "protocol": "inspector",
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API (Local)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["start:debug"],
      "cwd": "${workspaceFolder}/api",
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API Tests",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["test:debug"],
      "cwd": "${workspaceFolder}/api",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
